<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgMenuDetail"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/warung_placeholder"/>

        <TextView
            android:id="@+id/tvNamaMenuDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Menu"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tvHargaMenuDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga"
            android:textSize="18sp"
            android:layout_marginTop="4dp"/>

        <!-- DESKRIPSI MENU -->

        <TextView
            android:id="@+id/tvDeskripsiMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deskripsi menu"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:gravity="center"/>


        <!-- QUANTITY -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_button"
                android:text="-"
                android:textColor="@android:color/white"
                android:textSize="28sp"/>

            <TextView
                android:id="@+id/tvJumlah"
                android:layout_width="60dp"
                android:layout_height="50dp"
                android:text="1"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_button"
                android:text="+"
                android:textColor="@android:color/white"
                android:textSize="28sp"/>

        </LinearLayout>


        <!-- CATATAN PEMBELI -->

        <EditText
            android:id="@+id/etCatatan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tambahkan catatan (contoh: tidak pedas)"
            android:layout_marginTop="20dp"/>


        <!-- BUTTON KERANJANG -->

        <Button
            android:id="@+id/btnKeranjang"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Masukkan ke Keranjang"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>